{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "devit-ua",
	"compatibility_date": "2025-09-02",
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true
	},
	"main": "./src/server.ts",
	"services": [
		{
			"binding": "DATA_SERVICE",
			"service": "devit-ds-dev"
		}
	],
	"env": {
		/**
		 * Local / Development environment
		 */
		"dev": {
			"name": "devit-ua-dev",
			"services": [
				{
					"binding": "DATA_SERVICE",
					"service": "devit-ds-dev"
				}
			]
		},
		/**
		 * Remote / Staging environment
		 */
		"staging": {
			"name": "devit-ua-staging",
			// "routes": [
			//   {
			//     "custom_domain": true,
			//     "pattern": "staging.YOUR_DOMAIN.COM"
			//   }
			// ],
			"services": [
				{
					"binding": "DATA_SERVICE",
					"service": "devit-ds-staging"
				}
			]
		},
		/**
		 * Remote / Production environment
		 */
		"production": {
			"name": "devit-ua-production",
			// "routes": [
			//   {
			//     "custom_domain": true,
			//     "pattern": "YOUR_DOMAIN.COM"
			//   }
			// ],
			"services": [
				{
					"binding": "DATA_SERVICE",
					"service": "devit-ds-production"
				}
			]
		}
	}
}
